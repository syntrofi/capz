# ── Deployer ───────────────────────────────────────────────────────────────────
# Private key of the deployment wallet (without 0x prefix)
DEPLOYER_KEY=

# ── RPC endpoints ──────────────────────────────────────────────────────────────
# Get from Alchemy (https://dashboard.alchemy.com) or Infura
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
OPTIMISM_RPC_URL=https://mainnet.optimism.io
OPTIMISM_SEPOLIA_RPC_URL=https://sepolia.optimism.io

# ── Block explorer API keys (for contract verification) ───────────────────────
# Basescan: https://basescan.org/myapikey
BASESCAN_API_KEY=

# Optimism Etherscan: https://optimistic.etherscan.io/myapikey
OPTIMISM_ETHERSCAN_API_KEY=

# ── Legacy / optional ──────────────────────────────────────────────────────────
SEPOLIA_RPC_URL=
ETHERSCAN_API_KEY=

# ── Auto-verification flag ─────────────────────────────────────────────────────
# Set to "true" when deploying to mainnet to auto-submit verification
VERIFY_CONTRACTS=false
