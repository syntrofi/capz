# ── Contract addresses ─────────────────────────────────────────────────────────
# Filled in after running: cd packages/contracts && pnpm deploy:base-sepolia

# Base Sepolia (testnet)
NEXT_PUBLIC_BASE_SEPOLIA_FACTORY_ADDRESS=
NEXT_PUBLIC_BASE_SEPOLIA_IMPL_ADDRESS=

# Base Mainnet
NEXT_PUBLIC_BASE_FACTORY_ADDRESS=
NEXT_PUBLIC_BASE_IMPL_ADDRESS=

# Optimism Sepolia
NEXT_PUBLIC_OPTIMISM_SEPOLIA_FACTORY_ADDRESS=
NEXT_PUBLIC_OPTIMISM_SEPOLIA_IMPL_ADDRESS=

# Optimism Mainnet
NEXT_PUBLIC_OPTIMISM_FACTORY_ADDRESS=
NEXT_PUBLIC_OPTIMISM_IMPL_ADDRESS=

# ── Localhost / Hardhat (local dev only) ──────────────────────────────────────
# Set NEXT_PUBLIC_LOCAL_DEV=true to default to localhost chain
# Fill factory address after running: cd packages/contracts && pnpm deploy:local
NEXT_PUBLIC_LOCAL_DEV=false
NEXT_PUBLIC_LOCALHOST_FACTORY_ADDRESS=
NEXT_PUBLIC_LOCALHOST_IMPL_ADDRESS=

# ── Optional: WalletConnect project ID ────────────────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
